{
  "name": "papyrus",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "test": "bunx turbo run test test:root",
    "test:e2e": "bun run ./scripts/run-e2e.ts",
    "check-types": "bunx turbo run check-types",
    "autobump:staged": "bun run ./scripts/autobump-workspaces.ts",
    "check": "bunx turbo run check",
    "check:root": "bunx ultracite check:root",
    "test:root": "bun test ./scripts/autobump-workspaces.test.ts",
    "verify:pr": "bun run check && bun run check-types && bun run test && bun run test:e2e",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@changesets/cli": "^2.30.0",
    "@happy-dom/global-registrator": "^20.8.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "fake-indexeddb": "^6.2.5",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.20",
    "typescript": "^6.0.1-rc",
    "ultracite": "^7.3.2"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "lefthook"
  ]
}
