{
  "name": "papyrus",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "test": "bun test ./scripts/autobump-workspaces.test.ts && turbo run test",
    "check-types": "turbo run check-types",
    "autobump:staged": "bun run ./scripts/autobump-workspaces.ts",
    "check": "ultracite fix",
    "verify:pr": "bun x ultracite check && turbo run check && turbo run check-types && bun test ./scripts/autobump-workspaces.test.ts && turbo run test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^25.3.5",
    "@biomejs/biome": "^2.4.6",
    "bun-types": "^1.3.10",
    "lefthook": "^2.1.2",
    "turbo": "^2.8.14",
    "typescript": "^6.0.1-rc",
    "ultracite": "^7.2.5"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "lefthook"
  ]
}
