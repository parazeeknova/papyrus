{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["package.json", "bun.lock", "apps/collab/mix.lock"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "cache": true
    },
    "check": {
      "dependsOn": ["^check"],
      "cache": true
    },
    "//#check:root": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".github/**",
        "apps/**",
        "packages/**",
        "scripts/**"
      ],
      "outputs": [],
      "cache": true
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": true
    },
    "//#test:root": {
      "inputs": [
        "scripts/autobump-workspaces.ts",
        "scripts/autobump-workspaces.test.ts"
      ],
      "outputs": [],
      "cache": true
    },
    "test:e2e": {
      "cache": false
    },
    "format": {
      "dependsOn": ["^format"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
