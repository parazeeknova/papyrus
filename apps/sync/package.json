{
  "name": "@papyrus/sync",
  "version": "1.0.50",
  "scripts": {
    "build": "bun run build:minify",
    "build:minify": "bun build --target bun --minify --outfile ./dist/index.js ./src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "start": "bun ./dist/index.js",
    "check-types": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "@papyrus/core": "workspace:*",
    "@papyrus/logs": "workspace:*",
    "elysia": "^1.4.27",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  },
  "module": "src/index.js"
}
